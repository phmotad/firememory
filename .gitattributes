# Normalize line endings
* text=auto eol=lf

# Windows scripts keep CRLF
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Go source
*.go text eol=lf diff=golang

# Docs
*.md text eol=lf
*.txt text eol=lf

# Data / binary
*.fbrain binary
*.onnx binary
*.ort binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.png binary
*.gif binary
