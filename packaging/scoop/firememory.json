  "version": "PLACEHOLDER_VERSION",
  "description": "Local-first semantic memory engine for AI agents",
  "homepage": "https://github.com/phmotad/firememory",
  "license": "Apache-2.0",
  "architecture": {
    "64bit": {
      "url": "https://github.com/phmotad/firememory/releases/download/vPLACEHOLDER_VERSION/firememory_PLACEHOLDER_VERSION_windows_amd64.zip",
      "hash": "PLACEHOLDER_SHA256_WINDOWS_AMD64"
